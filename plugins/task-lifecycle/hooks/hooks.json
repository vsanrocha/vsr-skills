{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node ./session-start.js", "timeout": 30 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "node ./session-end.js", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node ./stop-verify.js", "timeout": 300 },
          { "type": "command", "command": "node ./learn-capture.js", "timeout": 30 },
          { "type": "command", "command": "node ./research-reminder.js", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node ./secret-detection.js", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node ./dangerous-op-guard.js", "timeout": 5 },
          { "type": "command", "command": "node ./pre-commit-check.js", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ./post-edit-lint.js", "timeout": 120 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node ./test-failure-check.js", "timeout": 5 }
        ]
      },
      {
        "matcher": "Grep|Bash",
        "hooks": [
          { "type": "command", "command": "node ./truncation-check.js", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node ./drift-detector.js", "timeout": 5 },
          { "type": "command", "command": "node ./correction-detector.js", "timeout": 5 }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node ./pre-compact.js", "timeout": 30 }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node ./post-compact.js", "timeout": 30 }
        ]
      }
    ]
  }
}
