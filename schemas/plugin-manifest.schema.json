{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClaudePluginManifest",
  "description": "Schema for .claude-plugin/plugin.json (Claude Code plugin manifest)",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Plugin identifier and skill namespace"
    },
    "description": {
      "type": "string",
      "description": "Shown in plugin manager"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string" },
    "license": { "type": "string" }
  }
}
